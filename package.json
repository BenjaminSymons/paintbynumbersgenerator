{
  "name": "paint-by-numbers-generator",
  "version": "2.0.0",
  "description": "Generate paint by number images (vectorized with SVG) from any input image. Web app + CLI.",
  "license": "MIT",
  "author": "drake7707",
  "type": "module",
  "bin": {
    "paint-by-numbers-generator": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:web": "node scripts/build.mjs --web",
    "build:cli": "node scripts/build.mjs --cli",
    "build": "node scripts/build.mjs --web --cli",
    "start": "node scripts/build.mjs --serve",
    "dev": "node scripts/build.mjs --serve --watch",
    "cli": "node dist/cli.js",
    "check": "npm run typecheck && npm run lint && npm run build",
    "prepublishOnly": "npm run build:cli"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "globals": "^15.0.0",
    "@types/jquery": "^3.5.0",
    "@types/materialize-css": "^1.0.14",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "canvas": "^3.0.0",
    "minimist": "^1.2.8",
    "sharp": "^0.33.0"
  }
}
